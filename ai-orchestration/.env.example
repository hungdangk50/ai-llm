PORT=3000
# (5) AIGate — base URL (tương thích: JAVA_TOOL_SERVICE_URL)
AI_GATE_URL=http://localhost:8081

# JWT: dùng cùng secret với ai-gate (HS256) để decode roles/sub
JWT_SECRET=dev-secret-key-for-hs256-must-be-32bytes

# LLM: bedrock (AWS Converse) | caip (HTTP REST tới CAIP_BASE_URL)
AI_PROVIDER=bedrock

# MOCK_BEDROCK=true: mô phỏng Bedrock (mặc định). false: gọi AWS Bedrock Converse
MOCK_BEDROCK=true
AWS_REGION=ap-southeast-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
# Tùy chọn: model “lớn” khi prompt dài / giống code (xem modelRouter.ts)
# BEDROCK_MODEL_ID_LARGE=anthropic.claude-3-5-sonnet-20240620-v1:0

# Giới hạn theo spec
MAX_TOOL_LOOPS=5
BEDROCK_TIMEOUT_MS=60000

# --- CAIP (khi AI_PROVIDER=caip): POST JSON tới CAIP_BASE_URL + CAIP_COMPLETE_PATH ---
# MOCK_CAIP=true: dùng cùng luồng mock như Bedrock (không gọi mạng). false: cần CAIP_BASE_URL.
MOCK_CAIP=true
# CAIP_BASE_URL=https://your-caip-gateway.example.com
# CAIP_COMPLETE_PATH=/v1/llm/complete
# CAIP_API_KEY=
CAIP_MODEL_ID=default
# CAIP_MODEL_ID_LARGE=large-deployment-id
CAIP_TIMEOUT_MS=60000
